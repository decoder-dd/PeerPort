# PeerPort Client Environment Variables Example
# Copy this file to frontend/.env.local or frontend/.env and populate values.

# Soroban RPC Node Endpoint
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Soroban Smart Contract Addresses (Testnet)
# Replace these with your actual deployed contract IDs
NEXT_PUBLIC_REPUTATION_CONTRACT_ID=CDPEERPORTREPUTATION12345678901234567890123456789012345
NEXT_PUBLIC_MARKETPLACE_CONTRACT_ID=CDPEERPORTMARKETPLACE12345678901234567890123456789012345

# Stellar Asset Contract (SAC) Token Address used for escrow trading
# Testnet Native XLM Token SAC: CDLZRVEJ4AYGLFLUXH6FE6SRUTNR2YCR5HQBF3PWBVJOWLSNCK27BAT7
NEXT_PUBLIC_TOKEN_CONTRACT_ID=CDLZRVEJ4AYGLFLUXH6FE6SRUTNR2YCR5HQBF3PWBVJOWLSNCK27BAT7
